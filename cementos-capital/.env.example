# Cementos Capital — Variables de entorno
# Copiar este archivo a .env.local y completar los valores.
# Para desplegar a Vercel: copia estas variables al dashboard de Vercel → Settings → Environment Variables.

# ─── Supabase Cloud ───────────────────────────────────────────────────────────
# Obtener desde https://supabase.com/dashboard → tu proyecto → Settings → API

# URL del proyecto (pública — usada en cliente y servidor)
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co

# Clave anónima pública — respeta Row Level Security (RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Clave service_role — SOLO server-side. Omite RLS. NUNCA exponer al cliente.
# Ver Settings → API → service_role secret (hacer clic en "Reveal")
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>

# ─── Opcional: BD de tests de integración ────────────────────────────────────
# Si quieres correr db:smoke contra una BD de staging separada (no afecta producción).
# Si no se define, db:smoke usa las variables principales anteriores.
# SUPABASE_TEST_URL=https://<test-ref>.supabase.co
# SUPABASE_TEST_SERVICE_KEY=<test-service-key>

# ─── Solo para scripts de desarrollo ─────────────────────────────────────────
# PAT de Supabase CLI — solo para scripts de seed/admin (.seed-aliases.ts).
# NO necesario para producción ni Vercel.
# SUPABASE_PAT=sbp_<tu-personal-access-token>
