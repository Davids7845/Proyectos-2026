# URL de la app a testear. Default: producción Vercel.
# Para dev local usar: http://localhost:3000
PLAYWRIGHT_BASE_URL=https://cementos-capital.vercel.app

# Usuario de prueba en Supabase Auth (crear manualmente en el Dashboard).
# El usuario NO necesita permisos especiales — sólo autenticación normal.
PLAYWRIGHT_TEST_EMAIL=e2e-test@example.com
PLAYWRIGHT_TEST_PASSWORD=<generar-password-fuerte>

# OPCIONAL: credenciales service_role para limpieza de versiones E2E pre/post test.
# Si no se configuran, la limpieza se omite silenciosamente.
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
